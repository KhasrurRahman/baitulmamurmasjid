# Google Sheet "File > Share > Publish to web" থেকে প্রতিটি ট্যাবের CSV লিংক দিন
SHEET_DONATIONS_CSV_URL=
SHEET_DOCUMENTS_CSV_URL=

# ডোমেইন কেনার পর আসল সাইট URL দিন (যেমন https://baitulmamur.at) — OpenGraph/social preview লিংকের জন্য জরুরি
NEXT_PUBLIC_SITE_URL=

# গ্যালারি: পাবলিক Google Drive ফোল্ডার আইডি (folder লিংকের /folders/ এর পরের অংশ)
# ফোল্ডারে ছবি/ভিডিও যুক্ত করলে সাইটে অটো দেখা যাবে — CSV লাগে না
NEXT_PUBLIC_DRIVE_PHOTOS_FOLDER_ID=
NEXT_PUBLIC_DRIVE_VIDEOS_FOLDER_ID=

# Google Cloud Console -> Drive API enable করে বানানো API key (Drive API-তে restrict করা, server-only — NEXT_PUBLIC_ প্রিফিক্স নেই, ব্রাউজারে যায় না)
DRIVE_API_KEY=
